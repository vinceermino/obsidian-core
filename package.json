{
    "name": "obsidian-core",
    "version": "1.1.0",
    "description": "Track workout sets and daily nutrition macros in Obsidian daily notes",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
